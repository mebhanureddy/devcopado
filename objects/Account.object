<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <validationRules>
        <fullName>bs</fullName>
        <active>true</active>
        <errorConditionFormula>AND(Number__c &lt;0, Number__c &lt;20) &amp;&amp;  Number__c &lt;&gt;10 &amp;&amp; Number__c  &lt;&gt; 20</errorConditionFormula>
        <errorMessage>Error</errorMessage> 
    </validationRules>
</CustomObject>
