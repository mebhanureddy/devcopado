    <fields>
        <fullName>hoo__c</fullName>
        <externalId>false</externalId>
        <formula>IF(ISBLANK(BillingState), &quot;None&quot;,
IF(CONTAINS(&quot;Goa:Gujarat:Karnataka:Maharashtra:Rajasthan&quot;, BillingState), &quot;West&quot;,
IF(CONTAINS(&quot;Chhattisgarh:Madhya Pradesh&quot;, BillingState), &quot;Central&quot;,
IF(CONTAINS(&quot;Arunachal Pradesh:West Bengal:Bihar:Jharkhand:Orrisa:Assam:Manipur:Meghalaya:Mizoram:Nagaland:Sikkim:Tripura&quot;, BillingState), &quot;East&quot;,
IF(CONTAINS(&quot;Andhra Pradesh:Telangana:Karnataka:Kerala:Tamil Nadu:Puducherry:Lakshadweep:Andaman and Nicobar&quot;, BillingState), &quot;South&quot;,
IF(CONTAINS(&quot;Jammu and Kashmir:HimachalPradesh:Punjab:Chandigarh:Uttarakhand:Haryana:Delhi:Rajasthan:Uttar Pradesh&quot;, BillingState), &quot;North&quot;,
&quot;Other&quot;))))))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>states</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>kjk__c</fullName>
        <externalId>false</externalId>
        <formula>IF(Website=&quot;&quot;, &quot;&quot;,
IF(
OR(LEFT(Website, 7) = &quot;http://&quot;,LEFT(Website, 8) =
&quot;https://&quot;),
HYPERLINK( Website , &quot;Click Here&quot; ),
HYPERLINK( &quot;http://&quot; &amp; Website , &quot;Click Here&quot; )
)
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>kjk</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>priority__c</fullName>
        <externalId>false</externalId>
        <formula>IF (AND (AnnualRevenue &gt; 100000,
CONTAINS (CASE (BillingCountry, &quot;India&quot;, &quot;INDIA&quot;, &quot;Ind&quot;, &quot;INDIA&quot;,
&quot;IND&quot;, &quot;INDIA&quot;, &quot;NA&quot;), &quot;INDIA&quot;)),
IF(ISPICKVAL(CustomerPriority__c, &quot;High&quot;), &quot;Hot&quot;,
IF(OR (ISPICKVAL (CustomerPriority__c, &quot;Low&quot;),
ISPICKVAL(CustomerPriority__c, &quot;Medium&quot;)), &quot;Warm&quot;, &quot;Cold&quot;)),
&quot;Cold&quot;)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>priority</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>rating__c</fullName>
        <externalId>false</externalId>
        <formula>IF (AND (AnnualRevenue &gt; 100000,
CONTAINS (CASE (BillingCountry, &quot;India&quot;, &quot;INDIA&quot;, &quot;Ind&quot;, &quot;INDIA&quot;,
&quot;IND&quot;, &quot;INDIA&quot;, &quot;NA&quot;), &quot;INDIA&quot;)),
IF(ISPICKVAL(Ownership, &quot;Public&quot;), &quot;Hot&quot;,
IF(OR (ISPICKVAL (Ownership, &quot;Private&quot;),
ISPICKVAL(Ownership, &quot;Subsidary&quot;)), &quot;Warm&quot;, &quot;Cold&quot;)),
&quot;Cold&quot;)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>rating</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>yahoo__c</fullName>
        <externalId>false</externalId>
        <formula>HYPERLINK(
&quot;http://search.yahoo.com/search?p=&quot;&amp;Name,
&quot;Yahoo Search&quot;)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>yahoo</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
