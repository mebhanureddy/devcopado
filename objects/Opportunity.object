    <recordTypes>
        <fullName>Utility_Opportunity</fullName>
        <active>true</active>
        <businessProcess>Utility Opportunities</businessProcess>
        <description>For use with opportunities for Utility customers</description>
        <label>Utility Opportunity</label>
        <picklistValues>
            <picklist>DeliveryInstallationStatus__c</picklist>
            <values>
