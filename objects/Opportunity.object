    <sharingModel>ReadWrite</sharingModel>
    <validationRules>
        <fullName>gdh</fullName>
        <active>false</active>
        <errorConditionFormula>AND (ISPICKVAL(   StageName , &quot;Closed Won&quot; ), ISBLANK( Delivery_Date__c ))</errorConditionFormula>
        <errorDisplayField>Delivery_Date__c</errorDisplayField>
        <errorMessage>Delivery Date is required for this stage.</errorMessage>
    </validationRules>
    <webLinks>
        <fullName>DeliveryStatus</fullName>
        <availability>online</availability>
        <displayType>link</displayType>
        <encodingKey>UTF-8</encodingKey>
        <hasMenubar>true</hasMenubar>
        <hasScrollbars>true</hasScrollbars>
        <hasToolbar>true</hasToolbar>
        <height>600</height>
        <isResizable>true</isResizable>
        <linkType>url</linkType>
        <masterLabel>Delivery Status</masterLabel>
        <openType>newWindow</openType>
        <position>none</position>
        <protected>false</protected>
        <showsLocation>true</showsLocation>
        <showsStatus>true</showsStatus>
        <url>http://www.fedex.com/cgi-bin/tracking?tracknumbers={!Opportunity_Tracking_Number}&amp;action=track&amp;language=english&amp;cntry_code=us</url>
    </webLinks>
</CustomObject>