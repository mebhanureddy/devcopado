        <externalId>false</externalId>
        <label>Languages</label>
        <length>100</length>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>LastCURequestDate</fullName>
    </fields>
    <fields>
        <fullName>LastCUUpdateDate</fullName>
