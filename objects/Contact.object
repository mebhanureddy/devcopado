    <fields>
        <fullName>SSN__c</fullName>
        <externalId>false</externalId>
        <label>SSN</label>
        <length>50</length>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Status__c</fullName>
        <label>Status</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Complete</fullName>
                    <default>false</default>
                    <label>Complete</label>
                </value>
                <value>
                    <fullName>Incomplete</fullName>
                    <default>false</default>
                    <label>Incomplete</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Title</fullName>
        <trackFeedHistory>false</trackFeedHistory>
    </fields>
    <fields>
        <fullName>Yahoo_Name__c</fullName>
        <externalId>false</externalId>
        <label>Yahoo Name</label>
        <length>50</length>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>ihi__c</fullName>
        <externalId>false</externalId>
        <formula>TRIM(LEFT(LastName, 5)) &amp;
&quot;-&quot; &amp; TRIM(RIGHT(SSN__c, 4))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>ihi</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>ojiu__c</fullName>
        <externalId>false</externalId>
        <formula>IF(OR(ISPICKVAL(Account.Rating, &quot;Hot&quot;), CONTAINS(Title, &quot;Executive&quot;)),
&quot;P1&quot;,
IF(OR(ISPICKVAL(Account.Rating, &quot;Warm&quot;), CONTAINS(Title, &quot;VP&quot;)), &quot;P2&quot;,
IF(ISPICKVAL(Account.Rating, &quot;Cold&quot;), &quot;P3&quot;,
&quot;25&quot;)
)
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>ojiu</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>tyu__c</fullName>
        <externalId>false</externalId>
        <formula>Account.Name</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>tyu</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>vdzv__c</fullName>
        <externalId>false</externalId>
        <formula>IF(Account.Website=&quot;&quot;, &quot;&quot;,
IF(
OR(LEFT(Account.Website, 7) = &quot;http://&quot;,LEFT(Account.Website, 8) =
&quot;https://&quot;),
HYPERLINK( Account.Website , &quot;Click Here&quot; ),
HYPERLINK( &quot;http://&quot; &amp; Account.Website , &quot;Click Here&quot; )
)
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>vdzv</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>yahu__c</fullName>
        <externalId>false</externalId>
        <formula>HYPERLINK(&quot;ymsgr:sendIM?&quot; &amp; Yahoo_Name__c,
IMAGE(&quot;http://opi.yahoo.com/online?u=&quot; &amp;
Yahoo_Name__c &amp;
&quot;&amp;m;=g&amp;t;=0&quot;, &quot;Yahoo&quot;))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>yahu</label>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <searchLayouts>
        <customTabListAdditionalFields>FULL_NAME</customTabListAdditionalFields>
        <customTabListAdditionalFields>ACCOUNT.NAME</customTabListAdditionalFields>
        <customTabListAdditionalFields>CONTACT.PHONE1</customTabListAdditionalFields>
