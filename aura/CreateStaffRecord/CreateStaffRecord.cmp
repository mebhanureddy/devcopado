<aura:component controller="CreateStaffRecord" 
                implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes" 
                access="global" >
    
    <!-- Define Attribute-->
    <aura:attribute name="staff" type="Staff__c" default="{'sobjectType': 'Staff__c',
                                                          'First_Name__c': '',
                                                          'Last_Name__c': '',
                                                          'Email__c': '', 
                                                          'Phone__c': '',
                                                          'Start_Date__c':''
                                                          }" access="GLOBAL"/>
    
    
    <article class="slds-card">
        <div class="slds-m-around--large">
            <h3>Please enter the staff information.</h3>
            <div class="slds-form-element slds-is-required" style="margin-top:5px">
                <label class="slds-form-element__label">
                <abbr class="slds-required" title="required">*</abbr>First Name</label>

                
                <ui:inputText class="slds-input" value="{!v.staff.First_Name__c}"/>
            </div>
            <div class="slds-form-element" style="margin-top:2px">
                 <label class="slds-form-element__label">
                <abbr class="slds-required" title="required">*</abbr>Last Name</label>
                
                <ui:inputText class="slds-input" value="{!v.staff.Last_Name__c}"/>
            </div>
            <div class="slds-form-element" style="margin-top:2px">
                <label class="slds-form-element__label">Email Address</label>
                <ui:inputEmail class="slds-input" value="{!v.staff.Email__c}"/>
            </div>
            <div class="slds-form-element" style="margin-top:2px">
                <label class="slds-form-element__label">Phone</label>
                <ui:inputText class="slds-input" value="{!v.staff.Phone__c}"/>
            </div>
            <div class="slds-form-element">
                <div class="slds-form-element__control">
                
                <label class="slds-form-element__label">
                <abbr class="slds-required" title="required">*</abbr>Start Date</label>
                    
                    <ui:inputDate aura:id="StartDate" label=""
                                  class="slds-input"
                                  labelClass="slds-form-element__label"
                                  value="{!v.staff.Start_Date__c}"
                                  displayDatePicker="true"/>
                    
                </div>
            </div>
            
                        
                        
            <div class="col-md-4 text-center" style="margin-top:15px">
                <ui:button class="slds-button slds-button--brand" press="{!c.create}">Create</ui:button>
            </div>            
        </div>
    </article>
</aura:component>