<aura:component controller="Apex_C4">
    <aura:attribute name="data" type="Account[]"/>
    <aura:attribute name="columns" type="list"/>
    <aura:handler  name="init" value="{!this}" action="{!c.show}"/>
     <div style="height: 300px">
        <lightning:datatable
                keyField="id"
                data="{! v.data }"
                columns="{! v.columns }"/>
    </div>
</aura:component>