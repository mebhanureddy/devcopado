<aura:component controller="datatabledisplay"
                implements="lightning:isUrlAddressable,force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickAction"
                access="global">
    <aura:attribute name="Phonerec" type="Boolean" default="false"/>
    <aura:attribute name="DetailPage" type="Boolean" default="false"/>
    <aura:attribute name="Listofrecords" type="List"/>
    <aura:attribute name="phonelist" type="Phone__c" default=""/>
    <aura:attribute name="watchtlist" type="Watch__c" default=""/>
    <aura:attribute name="idval" type="string"/>
    <aura:attribute name="phonerecList" type="List" default=""/>
    <aura:attribute name="watchrecord" type="Boolean" default="false"/>
    <aura:attribute name="selected" type="string"/>    
    <lightning:tabset selectedTabId="{!v.selected}" >
        <lightning:tab label="Home" onactive="{!c.BackToHome}">
        </lightning:tab>
        <lightning:tab label="Phones" id="Phone__c" onactive="{!c.Phone}">
        </lightning:tab>
        <lightning:tab label="Watches" id="Watch__c" onactive="{!c.Phone}">
        </lightning:tab>
    </lightning:tabset>
    <div>
        <aura:if isTrue="{!v.Phonerec}">
            <lightning:button label="new" title="Neutral action" onclick="{!c.createRecord}"/>
            <lightning:datatable data="{!v.phonerecList}"
                                 columns="{!v.Listofrecords}"
                                 hideCheckboxColumn="true"
                                 onrowaction="{!c.getid}"
                                 keyField="id"/>
        </aura:if>
    </div>
    <div>
        <aura:if isTrue="{!v.DetailPage}">
            <c:detailspage selected="{!v.idval}"/>
        </aura:if>
    </div>
</aura:component>