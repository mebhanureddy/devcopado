<aura:component implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId" 
                access="global" controller="Lightning_Accordion" >
    <aura:attribute name="AccCont" type="Account[]" default=""/>
    <aura:handler name="init" value="{!this}" action="{!c.ShowContacts}"/>     
    <lightning:accordion>
        <aura:iteration items="{!v.AccCont}" var="a">
            <lightning:accordionSection name="Name" label="{!a.Name}">
                <aura:iteration items="{!a.Contacts}" var="c">
                    <lightning:accordionSection name="{!c.LastName}" label="{!c.LastName}" />
                </aura:iteration>
            </lightning:accordionSection>
        </aura:iteration>
    </lightning:accordion>
</aura:component>