<apex:page controller="aasdf">
	<apex:form >
		<apex:pageBlock >
			<apex:pageBlockTable value="{!profile}" var="contact">
				<apex:column value="{!contact.Name}"/>
				<apex:column value="{!contact.Phone__c}"/>
				<apex:commandButton value="Goto DetailPage" action="{!gotoContactDetailPage}" reRender="none">
					<apex:param name="contactid" value="{!contact.Id}" assignTo="{!contactId}"/>
				</apex:commandButton>
			</apex:pageBlockTable>
		</apex:pageBlock>
	</apex:form>
</apex:page>